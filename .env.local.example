# ── Claude / Anthropic ───────────────────────────────────────────────
# Get from: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── YouTube / Google ──────────────────────────────────────────────────
# Create a project at https://console.cloud.google.com/
# Enable YouTube Data API v3, create OAuth 2.0 credentials
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:3000/api/youtube/callback

# ── TikTok ────────────────────────────────────────────────────────────
# Register at https://developers.tiktok.com/
# Create an app and request "video.upload" scope
TIKTOK_CLIENT_KEY=your_tiktok_client_key
TIKTOK_CLIENT_SECRET=your_tiktok_client_secret
TIKTOK_REDIRECT_URI=http://localhost:3000/api/tiktok/callback

# ── App ───────────────────────────────────────────────────────────────
NEXTAUTH_SECRET=any_random_string_here
NEXT_PUBLIC_APP_URL=http://localhost:3000
